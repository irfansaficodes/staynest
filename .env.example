# ===========================================
# StayNest Hotel Booking System - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# ===========================================

# --- Server Configuration ---
PORT=5000
NODE_ENV=development

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:5173

# --- MongoDB Atlas ---
MONGODB_CONNECTION_STRING=mongodb+srv://<username>:<password>@cluster.mongodb.net/hotelbooking?ssl=true&retryWrites=true&w=majority

# --- JWT Secret ---
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this

# --- Brevo SMTP (Email Service - FREE, 300 emails/day) ---
# 1. Sign up at https://www.brevo.com (free tier)
# 2. Go to Settings > SMTP & API > SMTP keys
# 3. Create an SMTP key, copy it below as SMTP_PASSWORD
# 4. SMTP_USER is your Brevo login email
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@email.com
SMTP_PASSWORD=your-brevo-smtp-key
SMTP_FROM_EMAIL=StayNest <noreply@yourdomain.com>

# --- Cloudinary (Image Storage) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Razorpay (Payment Gateway - Get LIVE keys) ---
RAZORPAY_KEY_ID=rzp_live_your-key-id
RAZORPAY_SECRET=your-secret-key

# --- Google OAuth (Optional) ---
GOOGLE_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_SECRET=your_google_client_secret
